local ESP = {Enabled = false}

local DistFromCenter = 80
local TriangleHeight = 16
local TriangleWidth = 16
local TriangleFilled = true
local TriangleTransparency = 0
local TriangleThickness = 1
local TriangleColor = Color3.fromRGB(255, 255, 255)
local AntiAliasing = false

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")

local V3 = Vector3.new
local V2 = Vector2.new
local CF = CFrame.new
local COS = math.cos
local SIN = math.sin
local RAD = math.rad
local DRAWING = Drawing.new
local ROUND = math.round

local function GetRelative(pos, char)
    if not char or not char.PrimaryPart then return V2(0,0) end
    local rootP = char.PrimaryPart.Position
    local camP = Camera.CFrame.Position
    local relative = CF(V3(rootP.X, camP.Y, rootP.Z), camP):PointToObjectSpace(pos)
    return V2(relative.X, relative.Z)
end

local function RelativeToCenter(v)
    return Camera.ViewportSize/2 - v
end

local function RotateVect(v, a)
    a = RAD(a)
local function NewTriangle()
    local triangle = Drawing.new("Triangle")
    triangle.Visible = false
    triangle.Filled = true
    triangle.Thickness = 1
    return triangle
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= Player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            local rootPos, onScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                            if not onScreen then
                                if not cache[v] then
                                    cache[v] = NewTriangle()
                                end
                                local arrow = cache[v]
                                
                                local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                                local direction = (Vector2.new(rootPos.X, rootPos.Y) - center).Unit
                                local angle = math.atan2(direction.Y, direction.X)
                                
                                local distance = ESP_Module.Settings.Radius
                                local point1 = center + Vector2.new(math.cos(angle), math.sin(angle)) * distance
                                local point2 = center + Vector2.new(math.cos(angle - 0.2), math.sin(angle - 0.2)) * (distance - ESP_Module.Settings.Size)
                                local point3 = center + Vector2.new(math.cos(angle + 0.2), math.sin(angle + 0.2)) * (distance - ESP_Module.Settings.Size)
                                
                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck and v.TeamColor ~= Player.TeamColor then
                                    clr = Color3.fromRGB(255, 0, 0)
                                elseif ESP_Module.Settings.TeamCheck and v.TeamColor == Player.TeamColor then
                                    clr = Color3.fromRGB(0, 255, 0)
                                end
                                if ESP_Module.Settings.TeamColor and v.TeamColor then
                                    clr = v.TeamColor.Color
                                end
                                
                                arrow.PointA = point1
                                arrow.PointB = point2
                                arrow.PointC = point3
                                arrow.Color = clr
                                arrow.Visible = true
                            else 
                                if cache[v] then cache[v].Visible = false end
                            end
                        else 
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end
                
                for p, arrow in pairs(cache) do
                    if not p or not p.Parent then
                        arrow:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, arrow in pairs(cache) do
            if arrow and type(arrow.Remove) == "function" then
                arrow:Remove()
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
