local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Size = 16,
    Radius = 130,
    TeamCheck = true,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")

local function NewTriangle()
    local t = Drawing.new("Triangle")
    t.Visible = false
    t.Filled = true
    t.Thickness = 1
    return t
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= Player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            local rootPos, onScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                            if not onScreen then
                                if not cache[v] then
                                    cache[v] = NewTriangle()
                                end
                                local arrow = cache[v]

                                local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                                local dir = (Vector2.new(rootPos.X, rootPos.Y) - center).Unit
                                local angle = math.atan2(dir.Y, dir.X)

                                local r = ESP_Module.Settings.Radius
                                local s = ESP_Module.Settings.Size
                                local tip   = center + Vector2.new(math.cos(angle),          math.sin(angle))          * r
                                local baseL = center + Vector2.new(math.cos(angle - 0.45),   math.sin(angle - 0.45))   * (r - s)
                                local baseR = center + Vector2.new(math.cos(angle + 0.45),   math.sin(angle + 0.45))   * (r - s)

                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck then
                                    clr = (v.TeamColor == Player.TeamColor)
                                        and Color3.fromRGB(0, 255, 0)
                                        or  Color3.fromRGB(255, 0, 0)
                                end

                                arrow.PointA = tip
                                arrow.PointB = baseL
                                arrow.PointC = baseR
                                arrow.Color  = clr
                                arrow.Visible = true
                            else
                                if cache[v] then cache[v].Visible = false end
                            end
                        else
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end

                for p, arrow in pairs(cache) do
                    if not p or not p.Parent then
                        arrow:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, arrow in pairs(cache) do
            if arrow then arrow:Remove() end
        end
        table.clear(cache)
    end
end

return ESP_Module
