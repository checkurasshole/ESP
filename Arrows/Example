-- Original by Blissful#4992, wrapped as module

local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    TeamCheck = true,
    MaxDistance = 500,
}

local DistFromCenter = 80
local TriangleHeight = 16
local TriangleWidth = 16
local TriangleFilled = true
local TriangleTransparency = 0
local TriangleThickness = 1
local TriangleColor = Color3.fromRGB(255, 255, 255)
local AntiAliasing = false

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))

local V3 = Vector3.new
local V2 = Vector2.new
local CF = CFrame.new
local COS = math.cos
local SIN = math.sin
local RAD = math.rad
local DRAWING = Drawing.new
local ROUND = math.round

local function GetRelative(pos, char)
    if not char then return V2(0,0) end
    local rootP = char.PrimaryPart.Position
    local camP = Camera.CFrame.Position
    local relative = CF(V3(rootP.X, camP.Y, rootP.Z), camP):PointToObjectSpace(pos)
    return V2(relative.X, relative.Z)
end

local function RelativeToCenter(v)
    return Camera.ViewportSize/2 - v
end

local function RotateVect(v, a)
    a = RAD(a)
    local x = v.x * COS(a) - v.y * SIN(a)
    local y = v.x * SIN(a) + v.y * COS(a)
    return V2(x, y)
end

local function AntiA(v)
    if not AntiAliasing then return v end
    return V2(ROUND(v.x), ROUND(v.y))
end

local function DrawTriangle(color)
    local l = DRAWING("Triangle")
    l.Visible = false
    l.Color = color
    l.Filled = TriangleFilled
    l.Thickness = TriangleThickness
    l.Transparency = 1 - TriangleTransparency
    return l
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= Player then
                        local char = p.Character
                        if char and char:FindFirstChildOfClass("Humanoid") and char.PrimaryPart and char:FindFirstChildOfClass("Humanoid").Health > 0 then
                            local dist = (Camera.CFrame.Position - char.PrimaryPart.Position).Magnitude
                            local _, vis = Camera:WorldToViewportPoint(char.PrimaryPart.Position)
                            if not vis and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[p] then
                                    local clr = TriangleColor
                                    if ESP_Module.Settings.TeamCheck then
                                        clr = (p.TeamColor == Player.TeamColor) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                                    end
                                    cache[p] = DrawTriangle(clr)
                                end
                                local arrow = cache[p]

                                local rel = GetRelative(char.PrimaryPart.Position, Player.Character)
                                local direction = rel.Unit
                                if direction.Magnitude > 0 then
                                    local base  = direction * DistFromCenter
                                    local sideL = DistFromCenter / 2
                                    local baseL = base + RotateVect(direction,  90) * (TriangleWidth / 2)
                                    local baseR = base + RotateVect(direction, -90) * (TriangleWidth / 2)
                                    local tip   = direction * (DistFromCenter + TriangleHeight)

                                    local clr = TriangleColor
                                    if ESP_Module.Settings.TeamCheck then
                                        clr = (p.TeamColor == Player.TeamColor) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                                    end
                                    arrow.Color = clr

                                    arrow.PointA = AntiA(RelativeToCenter(baseL))
                                    arrow.PointB = AntiA(RelativeToCenter(baseR))
                                    arrow.PointC = AntiA(RelativeToCenter(tip))
                                    arrow.Visible = true
                                else
                                    arrow.Visible = false
                                end
                            else
                                if cache[p] then cache[p].Visible = false end
                            end
                        else
                            if cache[p] then cache[p].Visible = false end
                        end
                    end
                end

                for p, arrow in pairs(cache) do
                    if not p or not p.Parent then
                        arrow:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, arrow in pairs(cache) do
            if arrow then arrow:Remove() end
        end
        table.clear(cache)
    end
end

return ESP_Module
