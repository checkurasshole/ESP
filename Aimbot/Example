local Aimbot = {Enabled = false}

Aimbot.Settings = {
    AimMethod = "Mouse", -- "Mouse" or "Camera"
    TargetPart = "Head",
    Smoothness = 2, -- 1 to 20
    TeamCheck = true,
    TargetPlayers = true,
    TargetNPCs = false,
    AlwaysOn = false,
    WallCheck = true,
    ShowFOV = true,
    FOVRadius = 150,
    FOVColor = Color3.fromRGB(255, 255, 255),
    AimKey = "MouseButton2" -- "Right Click"
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local LocalPlayer = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))
local UserInputService = cloneref(game:GetService("UserInputService"))

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

local connection
local StickyTarget = nil
local AimActive = false

-- Keybind Listeners
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        AimActive = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        AimActive = false
    end
end)

local Mouse = cloneref(LocalPlayer:GetMouse())
local IsTeammate = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/IsTeammate.lua"))()
local NPCManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/NPCManager.lua"))()

-- Exact Targeting Loop
local function GetClosestTarget()
    local Target, Closest = nil, Aimbot.Settings.FOVRadius
    local targets = {}
    if Aimbot.Settings.TargetPlayers then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then table.insert(targets, p.Character) end
        end
    end
    if Aimbot.Settings.TargetNPCs then
        for _, n in ipairs(NPCManager:GetNPCs()) do table.insert(targets, n) end
    end

    for _, char in ipairs(targets) do
        if char ~= LocalPlayer.Character and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            
            local plr = Players:GetPlayerFromCharacter(char)
            if Aimbot.Settings.TeamCheck and plr and IsTeammate(plr) then continue end
            
            local Pos, OnScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
            if OnScreen then
                if Aimbot.Settings.WallCheck then
                    local Parts = Camera:GetPartsObscuringTarget({char.HumanoidRootPart.Position}, {LocalPlayer.Character, char})
                    if #Parts > 0 then continue end
                end

                local Dist = (Vector2.new(Pos.X, Pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if Dist < Closest then
                    Closest = Dist
                    Target = char
                end
            end
        end
    end
    return Target
end

function Aimbot:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = true
            RS:BindToRenderStep("MspaintAim", Enum.RenderPriority.Camera.Value + 1, function()
                FOVCircle.Visible = (Aimbot.Settings.ShowFOV and true or false)
                FOVCircle.Position = UserInputService:GetMouseLocation()
                FOVCircle.Radius = Aimbot.Settings.FOVRadius
                FOVCircle.Color = Aimbot.Settings.FOVColor

                local isAiming = Aimbot.Settings.AlwaysOn or AimActive

                if isAiming then
                    local NewTarget = GetClosestTarget()
                    if NewTarget then StickyTarget = NewTarget end
                end

                if StickyTarget then
                    local Hum = StickyTarget.Character and StickyTarget.Character:FindFirstChild("Humanoid")
                    if not StickyTarget.Character or not Hum or Hum.Health <= 0 then
                        StickyTarget = nil
                    elseif Aimbot.Settings.WallCheck and StickyTarget.Character:FindFirstChild("HumanoidRootPart") then
                        -- Continuously re-check walls on the locked target every frame
                        local Parts = Camera:GetPartsObscuringTarget(
                            {StickyTarget.Character.HumanoidRootPart.Position},
                            {LocalPlayer.Character, StickyTarget.Character}
                        )
                        if #Parts > 0 then StickyTarget = nil end
                    end
                end
                if not isAiming then StickyTarget = nil end

                if isAiming and StickyTarget then
                    local Part = StickyTarget.Character:FindFirstChild(Aimbot.Settings.TargetPart)
                    if Part then
                        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                        local smoothVal = Aimbot.Settings.Smoothness

                        if Aimbot.Settings.AimMethod == "Camera" then
                            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Part.Position), 1 / smoothVal)
                        end
                        
                        if Aimbot.Settings.AimMethod == "Mouse" and mousemoverel then
                            local MousePos = UserInputService:GetMouseLocation()
                            mousemoverel((ScreenPos.X - MousePos.X) / smoothVal, (ScreenPos.Y - MousePos.Y) / smoothVal)
                        end
                    end
                end
            end)
        end
    else
        if connection then
            RS:UnbindFromRenderStep("MspaintAim")
            connection = nil
        end
        FOVCircle.Visible = false
        AimActive = false
        StickyTarget = nil
    end
end

return Aimbot
