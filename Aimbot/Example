local Aimbot = {Enabled = false}

Aimbot.Settings = {
    AimMethod = "Mouse", -- "Mouse" or "Camera"
    TargetPart = "Head",
    Smoothness = 2, -- 1 to 20
    TeamCheck = true,
    LobbyCheck = false,
    AlwaysOn = false,
    WallCheck = true,
    ShowFOV = true,
    FOVRadius = 150,
    FOVColor = Color3.fromRGB(255, 255, 255),
    AimKey = "MouseButton2" -- "Right Click"
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LobbyDetector = getgenv().ESP_LobbyDetector or loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/LobbyDetector.lua"))()
local TargetManager = getgenv().ESP_TargetManager or loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/TargetManager.lua"))()

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

local connection
local StickyTarget = nil
local AimActive = false

-- Keybind Listeners
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        AimActive = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        AimActive = false
    end
end)

-- Advanced Team Check
local function IsTeammate(target)
    if not Aimbot.Settings.TeamCheck then return false end
    if target.Type == "NPC" then return false end
    
    local Player = target.Player
    if not Player then return false end
    
    if Player.Team == LocalPlayer.Team and Player.Team ~= nil then
        return true
    end
    
    if Player:GetAttribute("Team") == LocalPlayer:GetAttribute("Team") and Player:GetAttribute("Team") ~= nil then
        return true
    end

    local Char = target.Character
    if Char then
        local HRP = Char:FindFirstChild("HumanoidRootPart")
        if HRP and (HRP:FindFirstChild("teamatelabel") or HRP:FindFirstChild("TeammateLabel") or HRP:FindFirstChild("Marker")) then
            return true
        end
        
        local Head = Char:FindFirstChild("Head")
        if Head and (Head:FindFirstChild("TeammateLabel") or Head:FindFirstChild("FriendMarker")) then
            return true
        end

        for _, child in pairs(Char:GetDescendants()) do
            if child:IsA("BillboardGui") and (child.Name:lower():find("team") or child.Name:lower():find("friend")) then
                return true
            end
        end
    end
    
    return false
end

-- Exact Targeting Loop
local function GetClosestTarget()
    local Target, Closest = nil, Aimbot.Settings.FOVRadius
    for _, target in ipairs(TargetManager.GetTargets("Aimbot")) do
        local p = target.Player or target.Character
        local char = target.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
            
            if Aimbot.Settings.LobbyCheck and (target.Type == "Player" and LobbyDetector.IsPlayerInLobby(target.Player)) then continue end
            if IsTeammate(target) then continue end
            
            local Pos, OnScreen = Camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
            if OnScreen then
                if Aimbot.Settings.WallCheck then
                    local Parts = Camera:GetPartsObscuringTarget({char.HumanoidRootPart.Position}, {LocalPlayer.Character, char})
                    if #Parts > 0 then continue end
                end

                local Dist = (Vector2.new(Pos.X, Pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if Dist < Closest then
                    Closest = Dist
                    Target = target
                end
            end
        end
    end
    return Target
end

function Aimbot:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = true
            RS:BindToRenderStep("MspaintAim", Enum.RenderPriority.Camera.Value + 1, function()
                FOVCircle.Visible = (Aimbot.Settings.ShowFOV and true or false)
                FOVCircle.Position = UserInputService:GetMouseLocation()
                FOVCircle.Radius = Aimbot.Settings.FOVRadius
                FOVCircle.Color = Aimbot.Settings.FOVColor

                local isAiming = Aimbot.Settings.AlwaysOn or AimActive
                if Aimbot.Settings.LobbyCheck and LobbyDetector.LocalPlayerInLobby then isAiming = false end

                if isAiming then
                    local NewTarget = GetClosestTarget()
                    if NewTarget then StickyTarget = NewTarget end
                end

                if StickyTarget then
                    local Hum = StickyTarget.Character and StickyTarget.Character:FindFirstChild("Humanoid")
                    if not StickyTarget.Character or not Hum or Hum.Health <= 0 then StickyTarget = nil end
                end
                if not isAiming then StickyTarget = nil end

                if isAiming and StickyTarget then
                    local Part = StickyTarget.Character:FindFirstChild(Aimbot.Settings.TargetPart)
                    if Part then
                        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                        local smoothVal = Aimbot.Settings.Smoothness

                        if Aimbot.Settings.AimMethod == "Camera" then
                            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Part.Position), 1 / smoothVal)
                        end
                        
                        if Aimbot.Settings.AimMethod == "Mouse" and mousemoverel then
                            local MousePos = UserInputService:GetMouseLocation()
                            mousemoverel((ScreenPos.X - MousePos.X) / smoothVal, (ScreenPos.Y - MousePos.Y) / smoothVal)
                        end
                    end
                end
            end)
        end
    else
        if connection then
            RS:UnbindFromRenderStep("MspaintAim")
            connection = nil
        end
        FOVCircle.Visible = false
        AimActive = false
        StickyTarget = nil
    end
end

return Aimbot

