local Aimbot = {Enabled = false}

Aimbot.Settings = {
    AimMethod = "Mouse", -- "Mouse" or "Camera"
    TargetPart = "Head",
    Smoothness = 2, -- 1 to 20
    TeamCheck = true,
    WallCheck = true,
    ShowFOV = true,
    FOVRadius = 100,
    FOVColor = Color3.fromRGB(255, 255, 255),
    AimKey = "MouseButton2" -- "Right Click"
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Filled = false
FOVCircle.Transparency = 1

local connection
local aiming = false
local currentTarget = nil

-- IMPORTANT: Do not use gameProcessed here. If we do, right-clicking in Roblox (which spins the camera) 
-- will be flagged as "processed" and the aimbot will NEVER activate!
UIS.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        aiming = true
    end
end)

UIS.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        aiming = false
        currentTarget = nil
    end
end)

local function isVisible(targetPart)
    if not Aimbot.Settings.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Player.Character, Camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    local result = workspace:Raycast(origin, direction, raycastParams)
    if result then
        if result.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        end
        return false
    end
    return true
end

local function getClosestTarget()
    local closestDistance = Aimbot.Settings.FOVRadius
    local target = nil
    
    local mousePos = UIS:GetMouseLocation()

    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= Player then
            local char = v.Character
            if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char:FindFirstChild(Aimbot.Settings.TargetPart) then
                
                -- Team Check
                if Aimbot.Settings.TeamCheck then
                    local sameTeam = false
                    if v.Team and Player.Team and v.Team == Player.Team then
                        sameTeam = true
                    end
                    if sameTeam then continue end
                end

                local targetPart = char[Aimbot.Settings.TargetPart]
                local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < closestDistance then
                        if isVisible(targetPart) then
                            closestDistance = dist
                            target = targetPart
                        end
                    end
                end
            end
        end
    end
    return target
end

local function isValidTarget(targetPart)
    if not targetPart or not targetPart.Parent then return false end
    local hum = targetPart.Parent:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    -- Check if still on screen and in FOV
    local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
    if not onScreen then return false end
    
    local mousePos = UIS:GetMouseLocation()
    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
    if dist > Aimbot.Settings.FOVRadius then return false end
    
    if not isVisible(targetPart) then return false end
    
    return true
end

function Aimbot:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function(deltaTime)
                -- Update FOV Circle
                local mousePos = UIS:GetMouseLocation()
                FOVCircle.Position = mousePos
                FOVCircle.Radius = Aimbot.Settings.FOVRadius
                FOVCircle.Color = Aimbot.Settings.FOVColor
                FOVCircle.Visible = Aimbot.Settings.ShowFOV

                if aiming then
                    -- Sticky Aim: If we don't have a target, or the current target is no longer valid, find a new one
                    if not currentTarget or not isValidTarget(currentTarget) then
                        currentTarget = getClosestTarget()
                    end

                    if currentTarget then
                        local Part = currentTarget
                        local PredPos = Part.Position
                        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(PredPos)
                        
                        local smoothVal = math.max(Aimbot.Settings.Smoothness, 1)

                        if Aimbot.Settings.AimMethod == "Camera" then
                            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, PredPos), 1 / smoothVal)
                        end
                        
                        if Aimbot.Settings.AimMethod == "Mouse" and mousemoverel then
                            local MousePos = UIS:GetMouseLocation()
                            mousemoverel((ScreenPos.X - MousePos.X) / smoothVal, (ScreenPos.Y - MousePos.Y) / smoothVal)
                        end
                    end
                else
                    currentTarget = nil
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        FOVCircle.Visible = false
        aiming = false
        currentTarget = nil
    end
end

return Aimbot
