local Aimbot = {Enabled = false}

Aimbot.Settings = {
    AimMethod = "Mouse", -- "Mouse" or "Camera"
    TargetPart = "Head", -- "Head", "HumanoidRootPart", etc.
    Smoothness = 0, -- 0 = instant, higher = slower
    TeamCheck = true,
    WallCheck = true,
    ShowFOV = true,
    FOVRadius = 100,
    FOVColor = Color3.fromRGB(255, 255, 255),
    ActivationMode = "Hold Key", -- "Hold Key" or "Always On"
    AimKey = "MouseButton2" -- Default to right click
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Filled = false
FOVCircle.Transparency = 1

local connection
local aiming = false

-- Update aiming state based on key press
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        aiming = true
    end
end)

UIS.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType.Name == Aimbot.Settings.AimKey or input.KeyCode.Name == Aimbot.Settings.AimKey then
        aiming = false
    end
end)

local function isVisible(targetPart)
    if not Aimbot.Settings.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Player.Character, Camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    local result = workspace:Raycast(origin, direction, raycastParams)
    if result then
        if result.Instance:IsDescendantOf(targetPart.Parent) then
            return true
        end
        return false
    end
    return true
end

local function getClosestTarget()
    local closestDistance = math.huge
    local closestTarget = nil
    
    local mousePos = UIS:GetMouseLocation()

    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= Player then
            local char = v.Character
            if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char:FindFirstChild(Aimbot.Settings.TargetPart) then
                
                -- Team Check
                if Aimbot.Settings.TeamCheck then
                    local sameTeam = v.Team ~= nil and Player.Team ~= nil and v.Team == Player.Team
                    if sameTeam then continue end
                end

                local targetPart = char[Aimbot.Settings.TargetPart]
                local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                
                if onScreen then
                    -- Wall Check
                    if isVisible(targetPart) then
                        local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                        if dist < Aimbot.Settings.FOVRadius and dist < closestDistance then
                            closestDistance = dist
                            closestTarget = targetPart
                        end
                    end
                end
            end
        end
    end
    return closestTarget
end

function Aimbot:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                -- Update FOV Circle
                local mousePos = UIS:GetMouseLocation()
                FOVCircle.Position = mousePos
                FOVCircle.Radius = Aimbot.Settings.FOVRadius
                FOVCircle.Color = Aimbot.Settings.FOVColor
                FOVCircle.Visible = Aimbot.Settings.ShowFOV

                local shouldAim = false
                if Aimbot.Settings.ActivationMode == "Always On" then
                    shouldAim = true
                elseif Aimbot.Settings.ActivationMode == "Hold Key" then
                    shouldAim = aiming
                end

                if shouldAim then
                    local target = getClosestTarget()
                    if target then
                        -- Math: if Smoothness is 0, factor is 1 (instant). If Smoothness is 10, factor is small.
                        local lerpFactor = 1
                        if Aimbot.Settings.Smoothness > 0 then
                            lerpFactor = 1 / (Aimbot.Settings.Smoothness * 2)
                        end

                        if Aimbot.Settings.AimMethod == "Mouse" then
                            local targetPos = Camera:WorldToViewportPoint(target.Position)
                            local moveX = (targetPos.X - mousePos.X) * lerpFactor
                            local moveY = (targetPos.Y - mousePos.Y) * lerpFactor
                            mousemoverel(moveX, moveY)
                        elseif Aimbot.Settings.AimMethod == "Camera" then
                            local lookCFrame = CFrame.new(Camera.CFrame.Position, target.Position)
                            Camera.CFrame = Camera.CFrame:Lerp(lookCFrame, lerpFactor)
                        end
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        FOVCircle.Visible = false
        aiming = false
    end
end

return Aimbot
