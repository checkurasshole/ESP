local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    Color = Color3.fromRGB(255, 255, 255),
    Size = 13,
    TeamCheck = true,
    TeamColor = false,
    ShowDistance = true,
    ShowHealth = true,
    ShowWeapon = true,
    MaxDistance = 10000,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local LobbyDetector = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/LobbyDetector.lua"))()

local function HealthBarLerp(t)
    -- t=0 is dead (red), t=1 is full HP (green)
    return Color3.fromRGB(
        math.floor(255 * (1 - t)),
        math.floor(255 * t),
        0
    )
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Center = true
    text.Outline = true
    text.Font = 2
    return text
end

local function NewLine(thickness)
    local line = Drawing.new("Line")
    line.Visible = false
    line.Thickness = thickness
    return line
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= Player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            local rootPart = char.HumanoidRootPart
                            local head = char:FindFirstChild("Head") or rootPart
                            local rootPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                            local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude
                            
                            local isLobby = false
                            if ESP_Module.Settings.LobbyCheck then
                                isLobby = LobbyDetector.IsPlayerInLobby(v) or LobbyDetector.LocalPlayerInLobby
                            end
                            
                            if onScreen and not isLobby and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[v] then
                                    cache[v] = {
                                        Name = NewText(),
                                        Weapon = NewText(),
                                        HealthBG = NewLine(3),
                                        HealthBar = NewLine(1.5)
                                    }
                                end
                                
                                local lib = cache[v]
                                local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                                local legPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                                
                                local boxHeight = math.abs(headPos.Y - legPos.Y)
                                local boxWidth = boxHeight / 2
                                
                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck and v.TeamColor ~= Player.TeamColor then
                                    clr = Color3.fromRGB(255, 0, 0)
                                elseif ESP_Module.Settings.TeamCheck and v.TeamColor == Player.TeamColor then
                                    clr = Color3.fromRGB(0, 255, 0)
                                end
                                if ESP_Module.Settings.TeamColor and v.TeamColor then
                                    clr = v.TeamColor.Color
                                end
                                
                                -- Name & Distance
                                local nameStr = v.Name
                                if ESP_Module.Settings.ShowDistance then
                                    nameStr = nameStr .. " [" .. math.floor(dist) .. "m]"
                                end
                                
                                lib.Name.Text = nameStr
                                lib.Name.Position = Vector2.new(headPos.X, headPos.Y - 15)
                                lib.Name.Color = clr
                                lib.Name.Size = ESP_Module.Settings.Size
                                lib.Name.Visible = true
                                
                                -- Weapon
                                if ESP_Module.Settings.ShowWeapon then
                                    local tool = char:FindFirstChildOfClass("Tool")
                                    if tool then
                                        lib.Weapon.Text = tool.Name
                                        lib.Weapon.Position = Vector2.new(legPos.X, legPos.Y + 5)
                                        lib.Weapon.Color = clr
                                        lib.Weapon.Size = ESP_Module.Settings.Size
                                        lib.Weapon.Visible = true
                                    else
                                        lib.Weapon.Visible = false
                                    end
                                else
                                    lib.Weapon.Visible = false
                                end
                                
                                -- Health Bar
                                if ESP_Module.Settings.ShowHealth then
                                    local healthRatio = char.Humanoid.Health / char.Humanoid.MaxHealth
                                    local barHeight = boxHeight * healthRatio
                                    
                                    local barX = headPos.X - (boxWidth / 2) - 5
                                    
                                    lib.HealthBG.From = Vector2.new(barX, headPos.Y)
                                    lib.HealthBG.To = Vector2.new(barX, legPos.Y)
                                    lib.HealthBG.Color = Color3.fromRGB(0, 0, 0)
                                    lib.HealthBG.Visible = true
                                    
                                    lib.HealthBar.From = Vector2.new(barX, legPos.Y)
                                    lib.HealthBar.To = Vector2.new(barX, legPos.Y - barHeight)
                                    lib.HealthBar.Color = HealthBarLerp(healthRatio)
                                    lib.HealthBar.Visible = true
                                else
                                    lib.HealthBG.Visible = false
                                    lib.HealthBar.Visible = false
                                end
                            else 
                                if cache[v] then
                                    cache[v].Name.Visible = false
                                    cache[v].Weapon.Visible = false
                                    cache[v].HealthBG.Visible = false
                                    cache[v].HealthBar.Visible = false
                                end
                            end
                        else 
                            if cache[v] then
                                cache[v].Name.Visible = false
                                cache[v].Weapon.Visible = false
                                cache[v].HealthBG.Visible = false
                                cache[v].HealthBar.Visible = false
                            end
                        end
                    end
                end
                
                for p, lib in pairs(cache) do
                    if not p or not p.Parent then
                        lib.Name:Remove()
                        lib.Weapon:Remove()
                        lib.HealthBG:Remove()
                        lib.HealthBar:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, lib in pairs(cache) do
            if lib.Name then lib.Name:Remove() end
            if lib.Weapon then lib.Weapon:Remove() end
            if lib.HealthBG then lib.HealthBG:Remove() end
            if lib.HealthBar then lib.HealthBar:Remove() end
        end
        table.clear(cache)
    end
end

return ESP_Module
