local ESP_Module = {Enabled = false}

local settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Size = 15,
    Transparency = 1,
    AutoScale = true
}

local space = game:GetService("Workspace")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = space.CurrentCamera
local RS = game:GetService("RunService")

local function NewText(color, size, transparency)
    local text = Drawing.new("Text")
    text.Visible = false
    text.Text = ""
    text.Position = Vector2.new(0, 0)
    text.Color = color
    text.Size = size
    text.Center = true
    text.Transparency = transparency
    return text
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            local rootPos, onScreen = camera:WorldToViewportPoint(char.HumanoidRootPart.Position)
                            if onScreen then
                                if not cache[v] then
                                    cache[v] = NewText(settings.Color, settings.Size, settings.Transparency)
                                end
                                local nameTxt = cache[v]
                                nameTxt.Text = v.Name
                                nameTxt.Position = Vector2.new(rootPos.X, rootPos.Y)
                                
                                if settings.AutoScale then
                                    local distance = (camera.CFrame.Position - char.HumanoidRootPart.Position).Magnitude
                                    nameTxt.Size = math.clamp(1/distance*1000, 2, 30)
                                else 
                                    nameTxt.Size = settings.Size
                                end
                                nameTxt.Visible = true
                            else 
                                if cache[v] then cache[v].Visible = false end
                            end
                        else 
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end
                
                for p, txt in pairs(cache) do
                    if not p or not p.Parent then
                        txt:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, txt in pairs(cache) do
            if txt and type(txt.Remove) == "function" then
                txt:Remove()
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
