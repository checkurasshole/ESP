local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    MaxDistance = 500
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))

local function ApplyESP(v)
    if v.Character and v.Character:FindFirstChildOfClass('Humanoid') then
        local HRP = v.Character:FindFirstChild("HumanoidRootPart")
        local dist = 0
        
        if HRP then
            dist = (Camera.CFrame.Position - HRP.Position).Magnitude
        end

        if ESP_Module.Enabled and dist <= ESP_Module.Settings.MaxDistance then
            v.Character.Humanoid.NameDisplayDistance = 9e9
            v.Character.Humanoid.NameOcclusion = "NoOcclusion"
            v.Character.Humanoid.HealthDisplayDistance = 9e9
            v.Character.Humanoid.HealthDisplayType = "AlwaysOn"
        else
            v.Character.Humanoid.NameDisplayDistance = 100
            v.Character.Humanoid.NameOcclusion = "OccludeAll"
            v.Character.Humanoid.HealthDisplayDistance = 100
            v.Character.Humanoid.HealthDisplayType = "DisplayWhenDamaged"
        end
        v.Character.Humanoid.Health = v.Character.Humanoid.Health
    end
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    for i,v in pairs(Players:GetPlayers()) do
        if v ~= Player then ApplyESP(v) end
    end
end

for i,v in pairs(Players:GetPlayers()) do
    if v ~= Player then
        ApplyESP(v)
        v.CharacterAdded:Connect(function()
            task.wait(0.33)
            ApplyESP(v)
        end)
    end
end

Players.PlayerAdded:Connect(function(v)
    if v ~= Player then
        ApplyESP(v)
        v.CharacterAdded:Connect(function()
            task.wait(0.33)
            ApplyESP(v)
        end)
    end
end)

-- Continuously refresh in case they move out of range
game:GetService("RunService").Heartbeat:Connect(function()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Player then ApplyESP(v) end
    end
end)

return ESP_Module
