local repo = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/"
local Library = loadstring(game:HttpGet(repo .. "Library.lua"))()
local ThemeManager = loadstring(game:HttpGet(repo .. "addons/ThemeManager.lua"))()
local SaveManager = loadstring(game:HttpGet(repo .. "addons/SaveManager.lua"))()

local Options = Library.Options
local Toggles = Library.Toggles

Library.ForceCheckbox = false
Library.ShowToggleFrameInKeybinds = true

local Window = Library:CreateWindow({
	Title = "combowick",
	Footer = "version: 1.0",
	Icon = 95816097006870,
	NotifySide = "Right",
	ShowCustomCursor = false,
	Size = UDim2.new(0, 420, 0, 450),
})

local Tabs = {
	Aimbot = Window:AddTab("Aimbot", "crosshair"),
	ESP = Window:AddTab("ESP Options", "eye"),
	["UI Settings"] = Window:AddTab("UI Settings", "settings"),
}

--------------------------------------------------------------------------------
-- ESP TAB
--------------------------------------------------------------------------------
local LeftGroupBox = Tabs.ESP:AddLeftGroupbox("Visuals", "boxes")
local RightGroupBox = Tabs.ESP:AddRightGroupbox("Team Check", "users")

local loadedModules = {}

local espScripts = {
	"Arrows", "Chams", "Name", "Radar", "Skeleton", "Tracers", "ViewTracer", "Health"
}

-- ESPs that support team check
local teamSupport = {
	Arrows = true, Chams = true, Name = true,
	Tracers = true, ViewTracer = true, Radar = true,
}

local function applySettings(name)
	local mod = loadedModules[name]
	if not mod then return end
	if mod.Settings then
		if teamSupport[name] and Toggles[name .. "TeamCheck"] then
			mod.Settings.TeamCheck = Toggles[name .. "TeamCheck"].Value
		end
		if Options.ESPDistanceLimit then
			mod.Settings.MaxDistance = Options.ESPDistanceLimit.Value
		end
		if Toggles.ESPLobbyCheck then
			mod.Settings.LobbyCheck = Toggles.ESPLobbyCheck.Value
		end
	end
end

local function loadESP(name)
	if not loadedModules[name] then
		local url = "https://raw.githubusercontent.com/checkurasshole/ESP/main/" .. name .. "/Example"
		local success, module = pcall(function()
			return loadstring(game:HttpGet(url))()
		end)
		if success and type(module) == "table" then
			loadedModules[name] = module
			applySettings(name)
		else
			Library:Notify({
				Title = "Error",
				Description = "Failed to load " .. name .. " ESP",
				Time = 5,
			})
			return false
		end
	end
	return true
end

for _, name in ipairs(espScripts) do
	LeftGroupBox:AddToggle(name .. "Toggle", {
		Text = name .. " ESP",
		Default = false,
		Tooltip = "Toggle " .. name .. " ESP",
		Callback = function(Value)
			if not loadESP(name) then
				Toggles[name .. "Toggle"]:SetValue(false)
				return
			end
			if loadedModules[name] and type(loadedModules[name].Toggle) == "function" then
				loadedModules[name]:Toggle(Value)
			end
		end,
	})
end

RightGroupBox:AddSlider("ESPDistanceLimit", {
	Text = "Max Distance",
	Default = 500,
	Min = 10,
	Max = 10000,
	Rounding = 0,
	Callback = function(Value)
		for _, name in ipairs(espScripts) do
			if loadedModules[name] and loadedModules[name].Settings then
				loadedModules[name].Settings.MaxDistance = Value
			end
		end
	end
})

RightGroupBox:AddToggle("ESPLobbyCheck", {
	Text = "Lobby Check (Ignore if in spawn/lobby)",
	Default = false,
	Callback = function(Value)
		for _, name in ipairs(espScripts) do
			if loadedModules[name] and loadedModules[name].Settings then
				loadedModules[name].Settings.LobbyCheck = Value
			end
		end
	end
})

-- Team check toggles (right side) - default ON
for _, name in ipairs(espScripts) do
	if teamSupport[name] then
		RightGroupBox:AddToggle(name .. "TeamCheck", {
			Text = name,
			Default = true,
			Tooltip = "Team check for " .. name .. " ESP",
			Callback = function(Value)
				if loadedModules[name] and loadedModules[name].Settings then
					loadedModules[name].Settings.TeamCheck = Value
				end
			end,
		})
	end
end

--------------------------------------------------------------------------------
-- AIMBOT TAB
--------------------------------------------------------------------------------
local AimSettingsBox = Tabs.Aimbot:AddLeftGroupbox("Settings", "settings")
local AimFOVBox = Tabs.Aimbot:AddRightGroupbox("FOV & Checks", "scan")

local function getAimbotMod()
    if not loadedModules["Aimbot"] then
        local url = "https://raw.githubusercontent.com/checkurasshole/ESP/main/Aimbot/Example"
        local success, module = pcall(function()
            return loadstring(game:HttpGet(url))()
        end)
        if success and type(module) == "table" then
            loadedModules["Aimbot"] = module
        else
            Library:Notify({Title = "Error", Description = "Failed to load Aimbot", Time = 5})
        end
    end
    return loadedModules["Aimbot"]
end

local function updateAimbotSetting(key, value)
    local mod = getAimbotMod()
    if mod and mod.Settings then
        mod.Settings[key] = value
    end
end

AimSettingsBox:AddToggle("AimbotToggle", {
    Text = "Enable Aimbot",
    Default = false,
    Callback = function(Value)
        local mod = getAimbotMod()
        if mod then mod:Toggle(Value) end
    end
})

AimSettingsBox:AddToggle("AimbotAlwaysOn", {
    Text = "Always On (Auto-Lock)",
    Default = false,
    Callback = function(Value) updateAimbotSetting("AlwaysOn", Value) end
})

AimSettingsBox:AddDropdown("AimbotMethod", {
    Values = { "Mouse", "Camera" },
    Default = "Mouse",
    Text = "Aim Method",
    Callback = function(Value) updateAimbotSetting("AimMethod", Value) end
})

AimSettingsBox:AddDropdown("AimbotTargetPart", {
    Values = { "Head", "HumanoidRootPart", "UpperTorso" },
    Default = "Head",
    Text = "Target Part",
    Callback = function(Value) updateAimbotSetting("TargetPart", Value) end
})

AimSettingsBox:AddSlider("AimbotSmoothness", {
    Text = "Smoothness",
    Default = 2,
    Min = 1,
    Max = 20,
    Rounding = 1,
    Callback = function(Value) updateAimbotSetting("Smoothness", Value) end
})

-- Need to map readable key names to Enum names or generic strings
AimSettingsBox:AddLabel("Aim Key"):AddKeyPicker("AimbotKey", {
    Default = "MouseButton2",
    NoUI = true,
    Text = "Aim Key",
    Callback = function() end, -- We don't use this callback, the module listens to UIS directly
    ChangedCallback = function(New) 
        -- KeyPicker returns the Name of the key, e.g. "MouseButton2", "E", "LeftShift"
        updateAimbotSetting("AimKey", New.Name)
    end
})

AimFOVBox:AddToggle("AimbotShowFOV", {
    Text = "Show FOV Circle",
    Default = true,
    Callback = function(Value) updateAimbotSetting("ShowFOV", Value) end
}):AddColorPicker("AimbotFOVColor", {
    Default = Color3.fromRGB(255, 255, 255),
    Title = "FOV Color",
    Callback = function(Value) updateAimbotSetting("FOVColor", Value) end
})

AimFOVBox:AddSlider("AimbotFOVRadius", {
    Text = "FOV Radius",
    Default = 150,
    Min = 10,
    Max = 800,
    Rounding = 0,
    Callback = function(Value) updateAimbotSetting("FOVRadius", Value) end
})

AimFOVBox:AddToggle("AimbotTeamCheck", {
    Text = "Team Check",
    Default = true,
    Callback = function(Value) updateAimbotSetting("TeamCheck", Value) end
})

AimFOVBox:AddToggle("AimbotWallCheck", {
    Text = "Wall Check",
    Default = true,
    Callback = function(Value) updateAimbotSetting("WallCheck", Value) end
})

AimFOVBox:AddToggle("AimbotLobbyCheck", {
    Text = "Lobby Check (Ignore if in spawn/lobby)",
    Default = false,
    Callback = function(Value) updateAimbotSetting("LobbyCheck", Value) end
})

--------------------------------------------------------------------------------
-- UI SETTINGS TAB
--------------------------------------------------------------------------------
local MenuGroup = Tabs["UI Settings"]:AddLeftGroupbox("Menu", "wrench")

MenuGroup:AddToggle("KeybindMenuOpen", {
	Default = Library.KeybindFrame.Visible,
	Text = "Open Keybind Menu",
	Callback = function(value)
		Library.KeybindFrame.Visible = value
	end,
})
MenuGroup:AddDropdown("NotificationSide", {
	Values = { "Left", "Right" },
	Default = "Right",
	Text = "Notification Side",
	Callback = function(Value)
		Library:SetNotifySide(Value)
	end,
})
MenuGroup:AddDropdown("DPIDropdown", {
	Values = { "50%", "75%", "100%", "125%", "150%", "175%", "200%" },
	Default = "100%",
	Text = "DPI Scale",
	Callback = function(Value)
		Value = Value:gsub("%%", "")
		local DPI = tonumber(Value)
		Library:SetDPIScale(DPI)
	end,
})

MenuGroup:AddDivider()
MenuGroup:AddLabel("Menu bind")
	:AddKeyPicker("MenuKeybind", { Default = "RightShift", NoUI = true, Text = "Menu keybind" })

MenuGroup:AddButton("Unload", function()
	Library:Unload()
end)

--------------------------------------------------------------------------------
-- FLOATING TOGGLE BUTTON (MOBILE/PC)
--------------------------------------------------------------------------------
local CoreGui = game:GetService("CoreGui")
local ToggleGui = Instance.new("ScreenGui")
ToggleGui.Name = "CombowickToggleUI"
-- Use a protected parent if possible to avoid detection, otherwise CoreGui
local gethui = gethui or function() return CoreGui end
ToggleGui.Parent = gethui()

local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Parent = ToggleGui
ToggleBtn.Size = UDim2.new(0, 50, 0, 50)
ToggleBtn.Position = UDim2.new(0, 10, 0, 10)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
ToggleBtn.BorderColor3 = Color3.fromRGB(60, 60, 60)
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.Font = Enum.Font.Code
ToggleBtn.TextSize = 14
ToggleBtn.Text = "Menu"
ToggleBtn.AutoButtonColor = true
ToggleBtn.Active = true
ToggleBtn.Draggable = true -- Allows mobile players to drag it around the screen

ToggleBtn.MouseButton1Click:Connect(function()
    Library:Toggle()
end)

Library:OnUnload(function()
    if ToggleGui then ToggleGui:Destroy() end
    print("Unloaded Combowick")
end)

Library.ToggleKeybind = Options.MenuKeybind

ThemeManager:SetLibrary(Library)
SaveManager:SetLibrary(Library)
SaveManager:IgnoreThemeSettings()
SaveManager:SetIgnoreIndexes({ "MenuKeybind", "AimbotKey" })
ThemeManager:SetFolder("combowick")
SaveManager:SetFolder("combowick/settings")

SaveManager:BuildConfigSection(Tabs["UI Settings"])
ThemeManager:ApplyToTab(Tabs["UI Settings"])
SaveManager:LoadAutoloadConfig()
