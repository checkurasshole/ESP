local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Thickness = 1.5,
    Transparency = 1,
    TeamCheck = true,
    TeamColor = false,
    MaxDistance = 500,
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))

local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    return line
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= Player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            local rootPart = char.HumanoidRootPart
                            local rootPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                            local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude
                            
                            if onScreen and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[v] then
                                    cache[v] = NewLine()
                                end
                                
                                local line = cache[v]
                                
                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck and v.TeamColor ~= Player.TeamColor then
                                    clr = Color3.fromRGB(255, 0, 0)
                                elseif ESP_Module.Settings.TeamCheck and v.TeamColor == Player.TeamColor then
                                    clr = Color3.fromRGB(0, 255, 0)
                                end
                                if ESP_Module.Settings.TeamColor and v.TeamColor then
                                    clr = v.TeamColor.Color
                                end
                                
                                line.Color = clr
                                line.Thickness = ESP_Module.Settings.Thickness
                                line.Transparency = ESP_Module.Settings.Transparency
                                
                                line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                line.To = Vector2.new(rootPos.X, rootPos.Y)
                                line.Visible = true
                            else 
                                if cache[v] then cache[v].Visible = false end
                            end
                        else 
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end
                
                for p, line in pairs(cache) do
                    if not p or not p.Parent then
                        line:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, line in pairs(cache) do
            if line then line:Remove() end
        end
        table.clear(cache)
    end
end

return ESP_Module
