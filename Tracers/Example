local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Thickness = 1.5,
    Transparency = 1,
    TeamCheck = true,
    TeamColor = false,
    MaxDistance = 500,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local LobbyDetector = getgenv().ESP_LobbyDetector or loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/LobbyDetector.lua"))()
local TargetManager = getgenv().ESP_TargetManager or loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/TargetManager.lua"))()

local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    return line
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, target in ipairs(TargetManager.GetTargets("ESP")) do
                    local v = target.Player or target.Character
                    local char = target.Character
                    if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                        local rootPart = char.HumanoidRootPart
                        local rootPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                        local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude
                        
                        local isLobby = false
                        if ESP_Module.Settings.LobbyCheck then
                            isLobby = LobbyDetector.LocalPlayerInLobby or (target.Type == "Player" and LobbyDetector.IsPlayerInLobby(target.Player))
                        end
                            
                            if onScreen and not isLobby and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[v] then
                                    cache[v] = NewLine()
                                end
                                
                                local line = cache[v]
                                
                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck and target.TeamColor ~= nil then
                                    if target.TeamColor ~= Player.TeamColor then
                                        clr = Color3.fromRGB(255, 0, 0)
                                    elseif target.TeamColor == Player.TeamColor then
                                        clr = Color3.fromRGB(0, 255, 0)
                                    end
                                end
                                if ESP_Module.Settings.TeamColor and target.TeamColor then
                                    clr = target.TeamColor.Color
                                end
                                
                                line.Color = clr
                                line.Thickness = ESP_Module.Settings.Thickness
                                line.Transparency = ESP_Module.Settings.Transparency
                                
                                line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                                line.To = Vector2.new(rootPos.X, rootPos.Y)
                                line.Visible = true
                            else 
                                if cache[v] then cache[v].Visible = false end
                            end
                        else 
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end
                
                for p, line in pairs(cache) do
                    if not p or not p.Parent then
                        line:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, line in pairs(cache) do
            if line then line:Remove() end
        end
        table.clear(cache)
    end
end

return ESP_Module

