local ESP_Module = {Enabled = false}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Mouse = Player:GetMouse()
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))
local UIS = cloneref(game:GetService("UserInputService"))

local function HealthBarLerp(t)
    return Color3.fromRGB(math.floor(255 * (1 - t)), math.floor(255 * t), 0)
end

local function NewCircle(Transparency, Color, Radius, Filled, Thickness)
    local c = Drawing.new("Circle")
    c.Transparency = Transparency
    c.Color = Color
    c.Visible = false
    c.Thickness = Thickness
    c.Position = Vector2.new(0, 0)
    c.Radius = Radius
    c.NumSides = math.clamp(Radius*55/100, 10, 75)
    c.Filled = Filled
    return c
end

ESP_Module.Settings = {
    Position = Vector2.new(150, Camera.ViewportSize.Y / 2),
    Radius = 100,
    Scale = 1,
    RadarBack = Color3.fromRGB(10, 10, 10),
    RadarBorder = Color3.fromRGB(75, 75, 75),
    LocalPlayerDot = Color3.fromRGB(255, 255, 255),
    PlayerDot = Color3.fromRGB(60, 170, 255),
    Team = Color3.fromRGB(0, 255, 0),
    Enemy = Color3.fromRGB(255, 0, 0),
    Health_Color = false,
    TeamCheck = true,
    MaxDistance = 500,
}
local RadarInfo = ESP_Module.Settings

local function GetRelative(pos)
    local char = Player.Character
    if char and char.PrimaryPart then
        local pmpart = char.PrimaryPart
        local camerapos = Vector3.new(Camera.CFrame.Position.X, pmpart.Position.Y, Camera.CFrame.Position.Z)
        local newcf = CFrame.new(pmpart.Position, camerapos)
        local r = newcf:PointToObjectSpace(pos)
        return r.X, r.Z
    else
        return 0, 0
    end
end

local cache = {}
local connection
local background, border, localDot, dragDot
local inset = game:GetService("GuiService"):GetGuiInset()
local dragging = false
local offset = Vector2.new(0, 0)

UIS.InputBegan:Connect(function(input)
    if ESP_Module.Enabled and input.UserInputType == Enum.UserInputType.MouseButton1 and (Vector2.new(Mouse.X, Mouse.Y + inset.Y) - RadarInfo.Position).Magnitude < RadarInfo.Radius then
        offset = RadarInfo.Position - Vector2.new(Mouse.X, Mouse.Y)
        dragging = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not background then
            background = NewCircle(0.9, RadarInfo.RadarBack, RadarInfo.Radius, true, 1)
            border = NewCircle(0.75, RadarInfo.RadarBorder, RadarInfo.Radius, false, 3)
            localDot = Drawing.new("Triangle")
            localDot.Thickness = 1
            localDot.Filled = true
            dragDot = NewCircle(1, Color3.fromRGB(255, 255, 255), 3, true, 1)
        end
        background.Visible = true
        border.Visible = true
        localDot.Visible = true
        
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                background.Position = RadarInfo.Position
                background.Radius = RadarInfo.Radius
                background.Color = RadarInfo.RadarBack

                border.Position = RadarInfo.Position
                border.Radius = RadarInfo.Radius
                border.Color = RadarInfo.RadarBorder
                
                localDot.Color = RadarInfo.LocalPlayerDot
                localDot.PointA = RadarInfo.Position + Vector2.new(0, -6)
                localDot.PointB = RadarInfo.Position + Vector2.new(-3, 6)
                localDot.PointC = RadarInfo.Position + Vector2.new(3, 6)
                
                if (Vector2.new(Mouse.X, Mouse.Y + inset.Y) - RadarInfo.Position).Magnitude < RadarInfo.Radius then
                    dragDot.Position = Vector2.new(Mouse.X, Mouse.Y + inset.Y)
                    dragDot.Visible = true
                else 
                    dragDot.Visible = false
                end
                if dragging then
                    RadarInfo.Position = Vector2.new(Mouse.X, Mouse.Y) + offset
                end

                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= Player then
                        local char = plr.Character
                        if char and char:FindFirstChildOfClass("Humanoid") and char.PrimaryPart and char:FindFirstChildOfClass("Humanoid").Health > 0 then
                            local dist = (char.PrimaryPart.Position - Player.Character.PrimaryPart.Position).Magnitude
                            
                            if dist <= RadarInfo.MaxDistance then
                                if not cache[plr] then
                                    cache[plr] = NewCircle(1, RadarInfo.PlayerDot, 3, true, 1)
                                end
                            local dot = cache[plr]
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            local scale = RadarInfo.Scale
                            local relx, rely = GetRelative(char.PrimaryPart.Position)
                            local newpos = RadarInfo.Position - Vector2.new(relx * scale, rely * scale) 
                            
                            if (newpos - RadarInfo.Position).Magnitude < RadarInfo.Radius-2 then 
                                dot.Radius = 3   
                                dot.Position = newpos
                            else 
                                local dist = (RadarInfo.Position - newpos).Magnitude
                                local calc = (RadarInfo.Position - newpos).Unit * (dist - RadarInfo.Radius)
                                dot.Radius = 2
                                dot.Position = Vector2.new(newpos.X + calc.X, newpos.Y + calc.Y)
                            end

                            -- Default: enemy red
                            dot.Color = RadarInfo.Enemy
                            if RadarInfo.TeamCheck then
                                -- Use .Team (actual team object) not .TeamColor to avoid false matches in teamless games
                                local sameTeam = plr.Team ~= nil and Player.Team ~= nil and plr.Team == Player.Team
                                dot.Color = sameTeam and RadarInfo.Team or RadarInfo.Enemy
                            end
                            if RadarInfo.Health_Color then
                                dot.Color = HealthBarLerp(hum.Health / hum.MaxHealth)
                            end
                            dot.Visible = true
                        else
                            if cache[plr] then cache[plr].Visible = false end
                        end
                    else
                        if cache[plr] then cache[plr].Visible = false end
                    end
                    end
                end
                
                for p, dot in pairs(cache) do
                    if not p or not p.Parent then
                        dot:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        if background then
            background:Remove()
            border:Remove()
            localDot:Remove()
            dragDot:Remove()
            background = nil
            border = nil
            localDot = nil
            dragDot = nil
        end
        for p, dot in pairs(cache) do
            if dot and type(dot.Remove) == "function" then
                dot:Remove()
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
