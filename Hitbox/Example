local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    TargetPart = "Both", -- "Head", "HRP", "Both"
    HeadSize = 5,
    HRPSize = 5,
    Color = Color3.fromRGB(255, 0, 0),
    LineThickness = 0.05,
    TargetPlayers = true,
    TargetNPCs = false,
    TeamCheck = true,
    MaxDistance = 500,
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))
local IsTeammate = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/IsTeammate.lua"))()
local NPCManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/NPCManager.lua"))()

-- Container in hidden UI so it doesn't show up in CoreGui scans
local gethui = gethui or function() return cloneref(game:GetService("CoreGui")) end
local holder = Instance.new("Folder")
holder.Name = "Hitbox_Visuals"
pcall(function() holder.Parent = gethui() end)
if not holder.Parent then holder.Parent = workspace end

-- boxCache[char] = { head = {box, part}, hrp = {box, part}, mode = "Head"/"HRP"/"Both" }
local boxCache = {}
local connection

local function CreateBox(part, size, color, thickness)
    local hitPart = Instance.new("Part")
    hitPart.Anchored = false
    hitPart.CanCollide = false
    hitPart.CanQuery = false
    hitPart.CanTouch = false
    hitPart.Massless = true
    hitPart.Transparency = 1
    hitPart.Size = Vector3.new(size, size, size)
    hitPart.CFrame = part.CFrame
    hitPart.Parent = holder

    local weld = Instance.new("WeldConstraint")
    weld.Part0 = part
    weld.Part1 = hitPart
    weld.Parent = hitPart

    local box = Instance.new("SelectionBox")
    box.Adornee = hitPart
    box.Color3 = color
    box.LineThickness = thickness
    box.SurfaceTransparency = 0.7
    box.SurfaceColor3 = color
    box.Parent = holder

    return { box = box, part = hitPart }
end

local function DestroyEntry(entry)
    if not entry then return end
    pcall(function() entry.box:Destroy() end)
    pcall(function() entry.part:Destroy() end)
end

local function ClearChar(char)
    local cached = boxCache[char]
    if cached then
        DestroyEntry(cached.head)
        DestroyEntry(cached.hrp)
        boxCache[char] = nil
    end
end

local function RebuildChar(char)
    -- Always destroy old boxes before rebuilding
    ClearChar(char)

    local s = ESP_Module.Settings
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")

    local entry = { mode = s.TargetPart }

    if (s.TargetPart == "HRP" or s.TargetPart == "Both") and hrp then
        entry.hrp = CreateBox(hrp, s.HRPSize, s.Color, s.LineThickness)
    end
    if (s.TargetPart == "Head" or s.TargetPart == "Both") and head then
        entry.head = CreateBox(head, s.HeadSize, s.Color, s.LineThickness)
    end

    boxCache[char] = entry
end

local function UpdateChar(char)
    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
        ClearChar(char)
        return
    end

    local plr = Players:GetPlayerFromCharacter(char)
    if ESP_Module.Settings.TeamCheck and plr and IsTeammate(plr) then
        ClearChar(char)
        return
    end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local dist = hrp and (Camera.CFrame.Position - hrp.Position).Magnitude or 9e9
    if dist > ESP_Module.Settings.MaxDistance then
        ClearChar(char)
        return
    end

    local cached = boxCache[char]
    local s = ESP_Module.Settings

    -- If no cache exists OR the TargetPart mode changed, rebuild from scratch
    if not cached or cached.mode ~= s.TargetPart then
        RebuildChar(char)
        return
    end

    -- Just update color/thickness on existing boxes each frame (cheap)
    if cached.hrp then
        cached.hrp.box.Color3 = s.Color
        cached.hrp.box.SurfaceColor3 = s.Color
        cached.hrp.box.LineThickness = s.LineThickness
    end
    if cached.head then
        cached.head.box.Color3 = s.Color
        cached.head.box.SurfaceColor3 = s.Color
        cached.head.box.LineThickness = s.LineThickness
    end
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.Heartbeat:Connect(function()
                local targets = {}
                if ESP_Module.Settings.TargetPlayers then
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= Player and p.Character then
                            table.insert(targets, p.Character)
                        end
                    end
                end
                if ESP_Module.Settings.TargetNPCs then
                    for _, n in ipairs(NPCManager:GetNPCs()) do
                        table.insert(targets, n)
                    end
                end

                local activeSet = {}
                for _, char in ipairs(targets) do
                    activeSet[char] = true
                    UpdateChar(char)
                end

                -- Remove boxes for chars no longer in the target list
                for char in pairs(boxCache) do
                    if not activeSet[char] then
                        ClearChar(char)
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for char in pairs(boxCache) do
            ClearChar(char)
        end
        table.clear(boxCache)
    end
end

return ESP_Module
