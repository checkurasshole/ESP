local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    TargetPart = "Both", -- "Head", "HRP", "Both"
    HeadSize = 5,
    HRPSize = 5,
    Transparency = 0.5,
    TeamCheck = true,
    MaxDistance = 500,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")
local LobbyDetector = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/LobbyDetector.lua"))()

local originalStates = {}
local connection

local function SaveState(part)
    if not part then return end
    if not originalStates[part] then
        originalStates[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            CanCollide = part.CanCollide,
            Massless = part.Massless
        }
    end
end

local function RestoreState(part)
    if not part then return end
    if originalStates[part] then
        part.Size = originalStates[part].Size
        part.Transparency = originalStates[part].Transparency
        part.CanCollide = originalStates[part].CanCollide
        part.Massless = originalStates[part].Massless
        originalStates[part] = nil
    end
end

local function ApplyHitbox(plr)
    local char = plr.Character
    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then return end
    
    local isLobby = false
    if ESP_Module.Settings.LobbyCheck then
        isLobby = LobbyDetector.IsPlayerInLobby(plr) or LobbyDetector.LocalPlayerInLobby
    end
    
    local isTeammate = false
    if ESP_Module.Settings.TeamCheck then
        if plr.TeamColor == Player.TeamColor then isTeammate = true end
    end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    
    local dist = 9e9
    if hrp then dist = (Camera.CFrame.Position - hrp.Position).Magnitude end
    
    local isValid = not isLobby and not isTeammate and dist <= ESP_Module.Settings.MaxDistance
    
    if ESP_Module.Enabled and isValid then
        -- Process HRP
        if hrp then
            SaveState(hrp)
            if ESP_Module.Settings.TargetPart == "HRP" or ESP_Module.Settings.TargetPart == "Both" then
                hrp.Size = Vector3.new(ESP_Module.Settings.HRPSize, ESP_Module.Settings.HRPSize, ESP_Module.Settings.HRPSize)
                hrp.Transparency = ESP_Module.Settings.Transparency
                hrp.CanCollide = false
                hrp.Massless = true
            else
                RestoreState(hrp)
            end
        end
        
        -- Process Head
        if head then
            SaveState(head)
            if ESP_Module.Settings.TargetPart == "Head" or ESP_Module.Settings.TargetPart == "Both" then
                head.Size = Vector3.new(ESP_Module.Settings.HeadSize, ESP_Module.Settings.HeadSize, ESP_Module.Settings.HeadSize)
                head.Transparency = ESP_Module.Settings.Transparency
                head.CanCollide = false
                head.Massless = true
            else
                RestoreState(head)
            end
        end
    else
        if hrp then RestoreState(hrp) end
        if head then RestoreState(head) end
    end
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.Heartbeat:Connect(function()
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= Player then
                        ApplyHitbox(p)
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= Player and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                local head = p.Character:FindFirstChild("Head")
                if hrp then RestoreState(hrp) end
                if head then RestoreState(head) end
            end
        end
    end
end

Players.PlayerRemoving:Connect(function(plr)
    if plr.Character then
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local head = plr.Character:FindFirstChild("Head")
        if hrp then originalStates[hrp] = nil end
        if head then originalStates[head] = nil end
    end
end)

return ESP_Module
