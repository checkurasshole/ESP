local Hitbox = {Enabled = false}

Hitbox.Settings = {
    ExpandHead = false,
    HeadSize = 10,
    ExpandHRP = true,
    HRPSize = 10,
    TeamCheck = false,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local LobbyDetector = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/LobbyDetector.lua"))()
local TargetManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/TargetManager.lua"))()

local cache = {}
local connection

local function CreateHitboxPart(name)
    local p = Instance.new("Part")
    p.Name = "ExpandedHitbox_" .. name
    p.Transparency = 1
    p.CanCollide = false
    p.Massless = true
    p.CastShadow = false
    p.Shape = Enum.PartType.Block
    return p
end

local function applyToTarget(target)
    local char = target.Character
    if not char then return end

    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end

    local isLobby = false
    if Hitbox.Settings.LobbyCheck then
        isLobby = LobbyDetector.LocalPlayerInLobby or (target.Type == "Player" and LobbyDetector.IsPlayerInLobby(target.Player))
    end
    
    local isTeammate = false
    if Hitbox.Settings.TeamCheck and target.Type == "Player" then
        isTeammate = target.Team == LocalPlayer.Team and target.Team ~= nil
    end

    if isLobby or isTeammate or hum.Sit then
        -- If they shouldn't have hitboxes, destroy them if they exist
        if cache[target] then
            for _, p in pairs(cache[target]) do
                p:Destroy()
            end
            cache[target] = nil
        end
        return
    end

    if not cache[target] then
        cache[target] = {}
    end

    -- Process Head
    if Hitbox.Settings.ExpandHead then
        local head = char:FindFirstChild("Head")
        if head then
            local p = cache[target]["Head"]
            if not p or not p.Parent then
                p = CreateHitboxPart("Head")
                p.CFrame = head.CFrame
                p.Parent = char
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = head
                weld.Part1 = p
                weld.Parent = p
                cache[target]["Head"] = p
            end
            p.Size = Vector3.new(Hitbox.Settings.HeadSize, Hitbox.Settings.HeadSize, Hitbox.Settings.HeadSize)
        end
    else
        if cache[target]["Head"] then
            cache[target]["Head"]:Destroy()
            cache[target]["Head"] = nil
        end
    end

    -- Process HRP
    if Hitbox.Settings.ExpandHRP then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local p = cache[target]["HumanoidRootPart"]
            if not p or not p.Parent then
                p = CreateHitboxPart("HumanoidRootPart")
                p.CFrame = hrp.CFrame
                p.Parent = char
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = hrp
                weld.Part1 = p
                weld.Parent = p
                cache[target]["HumanoidRootPart"] = p
            end
            p.Size = Vector3.new(Hitbox.Settings.HRPSize, Hitbox.Settings.HRPSize, Hitbox.Settings.HRPSize)
        end
    else
        if cache[target]["HumanoidRootPart"] then
            cache[target]["HumanoidRootPart"]:Destroy()
            cache[target]["HumanoidRootPart"] = nil
        end
    end
end

function Hitbox:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RunService.Heartbeat:Connect(function()
                for _, target in ipairs(TargetManager.GetTargets()) do
                    applyToTarget(target)
                end
                
                -- Cleanup dead/removed targets
                local currentTargets = {}
                for _, t in ipairs(TargetManager.GetTargets()) do
                    currentTargets[t] = true
                end
                for target, parts in pairs(cache) do
                    if not currentTargets[target] then
                        for _, p in pairs(parts) do p:Destroy() end
                        cache[target] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for _, parts in pairs(cache) do
            for _, p in pairs(parts) do
                if p then p:Destroy() end
            end
        end
        table.clear(cache)
    end
end

return Hitbox
