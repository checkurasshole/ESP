local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    TargetPart = "Both", -- "Head", "HRP", "Both"
    HeadSize = 5,
    HRPSize = 5,
    Color = Color3.fromRGB(255, 0, 0),
    LineThickness = 0.05,
    TargetPlayers = true,
    TargetNPCs = false,
    TeamCheck = true,
    MaxDistance = 500,
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))
local IsTeammate = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/IsTeammate.lua"))()
local NPCManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/NPCManager.lua"))()

-- SelectionBox-based hitbox: PURELY visual, no physics changes, no lag
local gethui = gethui or function() return cloneref(game:GetService("CoreGui")) end
local holder = Instance.new("Folder")
holder.Name = "Hitbox_Visuals"
pcall(function() holder.Parent = gethui() end)
if not holder.Parent then holder.Parent = workspace end

local boxCache = {} -- [char] = {head = SelectionBox, hrp = SelectionBox}
local connection

local function CreateBox(part, size, color, lineThickness)
    -- We use a SizeOffset SelectionBox trick:
    -- Create an invisible BasePart scaled to the desired hitbox size, 
    -- then parent a SelectionBox to it.
    local hitPart = Instance.new("Part")
    hitPart.Name = "HitboxVisualPart"
    hitPart.Anchored = false
    hitPart.CanCollide = false
    hitPart.CanQuery = false
    hitPart.CanTouch = false
    hitPart.Massless = true
    hitPart.Transparency = 1
    hitPart.Size = Vector3.new(size, size, size)
    hitPart.CFrame = part.CFrame
    
    -- Weld to the actual part so it moves with the character
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = part
    weld.Part1 = hitPart
    weld.Parent = hitPart
    hitPart.Parent = holder

    local box = Instance.new("SelectionBox")
    box.Adornee = hitPart
    box.Color3 = color
    box.LineThickness = lineThickness
    box.SurfaceTransparency = 0.6
    box.SurfaceColor3 = color
    box.Parent = holder

    return { box = box, part = hitPart, weld = weld }
end

local function DestroyBoxEntry(entry)
    if not entry then return end
    if entry.box then entry.box:Destroy() end
    if entry.part then entry.part:Destroy() end
    -- weld is parented to part so it auto-destroys
end

local function ClearChar(char)
    if boxCache[char] then
        DestroyBoxEntry(boxCache[char].head)
        DestroyBoxEntry(boxCache[char].hrp)
        boxCache[char] = nil
    end
end

local function UpdateChar(char)
    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
        ClearChar(char)
        return
    end

    local plr = Players:GetPlayerFromCharacter(char)
    if ESP_Module.Settings.TeamCheck and plr and IsTeammate(plr) then
        ClearChar(char)
        return
    end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    
    local dist = hrp and (Camera.CFrame.Position - hrp.Position).Magnitude or 9e9
    if dist > ESP_Module.Settings.MaxDistance then
        ClearChar(char)
        return
    end

    if not boxCache[char] then
        boxCache[char] = {}
    end

    local settings = ESP_Module.Settings
    local showHRP = settings.TargetPart == "HRP" or settings.TargetPart == "Both"
    local showHead = settings.TargetPart == "Head" or settings.TargetPart == "Both"

    -- HRP box
    if showHRP and hrp then
        if not boxCache[char].hrp then
            boxCache[char].hrp = CreateBox(hrp, settings.HRPSize, settings.Color, settings.LineThickness)
        end
        boxCache[char].hrp.box.Visible = true
    else
        if boxCache[char].hrp then
            boxCache[char].hrp.box.Visible = false
        end
    end

    -- Head box
    if showHead and head then
        if not boxCache[char].head then
            boxCache[char].head = CreateBox(head, settings.HeadSize, settings.Color, settings.LineThickness)
        end
        boxCache[char].head.box.Visible = true
    else
        if boxCache[char].head then
            boxCache[char].head.box.Visible = false
        end
    end
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.Heartbeat:Connect(function()
                -- Build target list
                local targets = {}
                if ESP_Module.Settings.TargetPlayers then
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= Player and p.Character then
                            table.insert(targets, p.Character)
                        end
                    end
                end
                if ESP_Module.Settings.TargetNPCs then
                    for _, n in ipairs(NPCManager:GetNPCs()) do
                        table.insert(targets, n)
                    end
                end

                -- Build a set of active chars
                local activeSet = {}
                for _, char in ipairs(targets) do
                    activeSet[char] = true
                    UpdateChar(char)
                end

                -- Clean up chars that left
                for char, _ in pairs(boxCache) do
                    if not activeSet[char] then
                        ClearChar(char)
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        -- Clean up all visual boxes
        for char, _ in pairs(boxCache) do
            ClearChar(char)
        end
    end
end

return ESP_Module
