local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    TargetPart = "Both", -- "Head", "HRP", "Both"
    HeadSize = 5,
    HRPSize = 5,
    Transparency = 0.5,
    TargetPlayers = true,
    TargetNPCs = false,
    TeamCheck = true,
    MaxDistance = 500,
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local Camera = cloneref(workspace.CurrentCamera)
local RS = cloneref(game:GetService("RunService"))
local IsTeammate = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/IsTeammate.lua"))()
local NPCManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/NPCManager.lua"))()

local originalStates = setmetatable({}, {__mode = "k"})
local connection

local function SaveState(part)
    if not part then return end
    if not originalStates[part] then
        originalStates[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            CanCollide = part.CanCollide,
            Massless = part.Massless
        }
    end
end

local function RestoreState(part)
    if not part then return end
    if originalStates[part] then
        if part.Size ~= originalStates[part].Size then part.Size = originalStates[part].Size end
        if part.Transparency ~= originalStates[part].Transparency then part.Transparency = originalStates[part].Transparency end
        if part.CanCollide ~= originalStates[part].CanCollide then part.CanCollide = originalStates[part].CanCollide end
        if part.Massless ~= originalStates[part].Massless then part.Massless = originalStates[part].Massless end
        originalStates[part] = nil
    end
end

local function ApplyHitbox(char)
    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then return end
    
    local isTeammate = false
    if ESP_Module.Settings.TeamCheck and char:FindFirstChild("Humanoid") then
        local plr = Players:GetPlayerFromCharacter(char)
        if plr and IsTeammate(plr) then isTeammate = true end
    end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    
    local dist = 9e9
    if hrp then dist = (Camera.CFrame.Position - hrp.Position).Magnitude end
    
    local isValid = not isTeammate and dist <= ESP_Module.Settings.MaxDistance
    
    if ESP_Module.Enabled and isValid then
        -- Process HRP
        if hrp then
            SaveState(hrp)
            if ESP_Module.Settings.TargetPart == "HRP" or ESP_Module.Settings.TargetPart == "Both" then
                local tSize = Vector3.new(ESP_Module.Settings.HRPSize, ESP_Module.Settings.HRPSize, ESP_Module.Settings.HRPSize)
                if hrp.Size ~= tSize then hrp.Size = tSize end
                if hrp.Transparency ~= ESP_Module.Settings.Transparency then hrp.Transparency = ESP_Module.Settings.Transparency end
                if hrp.CanCollide ~= false then hrp.CanCollide = false end
                if hrp.Massless ~= true then hrp.Massless = true end
            else
                RestoreState(hrp)
            end
        end
        
        -- Process Head
        if head then
            SaveState(head)
            if ESP_Module.Settings.TargetPart == "Head" or ESP_Module.Settings.TargetPart == "Both" then
                local tSize = Vector3.new(ESP_Module.Settings.HeadSize, ESP_Module.Settings.HeadSize, ESP_Module.Settings.HeadSize)
                if head.Size ~= tSize then head.Size = tSize end
                if head.Transparency ~= ESP_Module.Settings.Transparency then head.Transparency = ESP_Module.Settings.Transparency end
                if head.CanCollide ~= false then head.CanCollide = false end
                if head.Massless ~= true then head.Massless = true end
            else
                RestoreState(head)
            end
        end
    else
        if hrp then RestoreState(hrp) end
        if head then RestoreState(head) end
    end
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                local targets = {}
                if ESP_Module.Settings.TargetPlayers then
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p.Character then table.insert(targets, p.Character) end
                    end
                end
                if ESP_Module.Settings.TargetNPCs then
                    for _, n in ipairs(NPCManager:GetNPCs()) do table.insert(targets, n) end
                end

                for _, char in ipairs(targets) do
                    if char ~= Player.Character then
                        ApplyHitbox(char)
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for part, _ in pairs(originalStates) do
            RestoreState(part)
        end
    end
end

Players.PlayerRemoving:Connect(function(plr)
    -- Weak table automatically handles garbage collection when parts are destroyed
end)

return ESP_Module
