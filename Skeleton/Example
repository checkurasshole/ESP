local ESP_Module = {Enabled = false}
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Blissful4992/ESPs/main/UniversalSkeleton.lua"))()

local Skeletons = {}

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        for _, Player in next, game.Players:GetChildren() do
            if Player ~= game.Players.LocalPlayer then
                table.insert(Skeletons, Library:NewSkeleton(Player, true))
            end
        end
    else
        for _, skeleton in ipairs(Skeletons) do
            if skeleton and type(skeleton.Remove) == "function" then
                skeleton:Remove()
            end
            if skeleton and type(skeleton.Destroy) == "function" then
                skeleton:Destroy()
            end
        end
        Skeletons = {}
    end
end

game.Players.PlayerAdded:Connect(function(Player)
    if ESP_Module.Enabled and Player ~= game.Players.LocalPlayer then
        table.insert(Skeletons, Library:NewSkeleton(Player, true))
    end
end)

return ESP_Module
