local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    FillColor = Color3.fromRGB(255, 0, 0),
    FillTransparency = 0.5,
    OutlineColor = Color3.fromRGB(255, 255, 255),
    OutlineTransparency = 0,
    TeamCheck = true,
    MaxDistance = 10000,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RS = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Camera = workspace.CurrentCamera

local function IsInLobby(p)
    if not p or not p.Character then return false end
    if p.Character:FindFirstChildOfClass("ForceField") then return true end
    if p.Team and (p.Team.Name:lower():find("lobby") or p.Team.Name:lower():find("spectator") or p.Team.Name:lower():find("waiting")) then return true end
    return false
end

local cache = {}
local connection

local holder = Instance.new("Folder")
holder.Name = "ESP_Highlights"
pcall(function() holder.Parent = CoreGui end)
if not holder.Parent then
    holder.Parent = workspace
end

local function CreateHighlight()
    local h = Instance.new("Highlight")
    h.FillColor = ESP_Module.Settings.FillColor
    h.FillTransparency = ESP_Module.Settings.FillTransparency
    h.OutlineColor = ESP_Module.Settings.OutlineColor
    h.OutlineTransparency = ESP_Module.Settings.OutlineTransparency
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    return h
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= Player then
                        local char = plr.Character
                        if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char.PrimaryPart then
                            local isLobby = false
                            if ESP_Module.Settings.LobbyCheck then
                                isLobby = IsInLobby(plr) or IsInLobby(Player)
                            end
                            
                            local dist = (Camera.CFrame.Position - char.PrimaryPart.Position).Magnitude
                            if not isLobby and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[plr] then
                                    local h = CreateHighlight()
                                    h.Parent = holder
                                    cache[plr] = h
                                end
                                local h = cache[plr]
                                h.Adornee = char

                            local clr = ESP_Module.Settings.FillColor
                            if ESP_Module.Settings.TeamCheck then
                                clr = (plr.TeamColor == Player.TeamColor)
                                    and Color3.fromRGB(0, 255, 0)
                                    or  Color3.fromRGB(255, 0, 0)
                            end
                            h.FillColor = clr
                            h.FillTransparency = ESP_Module.Settings.FillTransparency
                            h.OutlineColor = ESP_Module.Settings.OutlineColor
                            h.OutlineTransparency = ESP_Module.Settings.OutlineTransparency
                                h.Enabled = true
                            else
                                if cache[plr] then cache[plr].Enabled = false end
                            end
                        else
                            if cache[plr] then cache[plr].Enabled = false end
                        end
                    end
                end

                for p, h in pairs(cache) do
                    if not p or not p.Parent then
                        h:Destroy()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, h in pairs(cache) do
            if h then h:Destroy() end
        end
        table.clear(cache)
        if holder and holder.Parent then
            holder:ClearAllChildren()
        end
    end
end

return ESP_Module
