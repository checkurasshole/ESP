local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    FillColor = Color3.fromRGB(255, 0, 0),
    FillTransparency = 0.5,
    OutlineColor = Color3.fromRGB(255, 255, 255),
    OutlineTransparency = 0,
    TeamCheck = true,
    TargetPlayers = true,
    TargetNPCs = false,
    MaxDistance = 500,
}

local cloneref = cloneref or function(...) return ... end
local Players = cloneref(game:GetService("Players"))
local Player = cloneref(Players.LocalPlayer)
local RS = cloneref(game:GetService("RunService"))
local CoreGui = cloneref(game:GetService("CoreGui"))
local Camera = cloneref(workspace.CurrentCamera)
local IsTeammate = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/IsTeammate.lua"))()
local NPCManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/checkurasshole/ESP/main/NPCManager.lua"))()

local cache = {}
local connection

local gethui = gethui or function() return CoreGui end

local holder = Instance.new("Folder")
holder.Name = "ESP_Highlights"
pcall(function() holder.Parent = gethui() end)
if not holder.Parent then
    holder.Parent = workspace
end

local function CreateHighlight()
    local h = Instance.new("Highlight")
    h.FillColor = ESP_Module.Settings.FillColor
    h.FillTransparency = ESP_Module.Settings.FillTransparency
    h.OutlineColor = ESP_Module.Settings.OutlineColor
    h.OutlineTransparency = ESP_Module.Settings.OutlineTransparency
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    return h
end

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                local targets = {}
                if ESP_Module.Settings.TargetPlayers then
                    for _, p in ipairs(Players:GetPlayers()) do table.insert(targets, p) end
                end
                if ESP_Module.Settings.TargetNPCs then
                    for _, n in ipairs(NPCManager:GetNPCs()) do table.insert(targets, n) end
                end

                for _, plr in ipairs(targets) do
                    if plr ~= Player then
                        local char = typeof(plr) == "Instance" and plr:IsA("Model") and plr or plr.Character
                        if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 and char.PrimaryPart then
                            local dist = (Camera.CFrame.Position - char.PrimaryPart.Position).Magnitude
                            if dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[plr] then
                                    local h = CreateHighlight()
                                    h.Parent = holder
                                    cache[plr] = h
                                end
                                local h = cache[plr]
                                h.Adornee = char

                            local clr = ESP_Module.Settings.FillColor
                            if ESP_Module.Settings.TeamCheck then
                                clr = IsTeammate(plr)
                                    and Color3.fromRGB(0, 255, 0)
                                    or  Color3.fromRGB(255, 0, 0)
                            end
                            h.FillColor = clr
                            h.FillTransparency = ESP_Module.Settings.FillTransparency
                            h.OutlineColor = ESP_Module.Settings.OutlineColor
                            h.OutlineTransparency = ESP_Module.Settings.OutlineTransparency
                                h.Enabled = true
                            else
                                if cache[plr] then cache[plr].Enabled = false end
                            end
                        else
                            if cache[plr] then cache[plr].Enabled = false end
                        end
                    end
                end

                for p, h in pairs(cache) do
                    if not p or not p.Parent then
                        h:Destroy()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, h in pairs(cache) do
            if h then h:Destroy() end
        end
        table.clear(cache)
        if holder and holder.Parent then
            holder:ClearAllChildren()
        end
    end
end

return ESP_Module
