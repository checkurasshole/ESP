local ESP_Module = {Enabled = false}

ESP_Module.Settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Thickness = 1.5,
    Transparency = 1,
    Length = 10,
    TeamCheck = true,
    TeamColor = false,
    MaxDistance = 10000,
    LobbyCheck = false,
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RS = game:GetService("RunService")

local function IsInLobby(p)
    if not p or not p.Character then return false end
    if p.Character:FindFirstChildOfClass("ForceField") then return true end
    if p.Team and (p.Team.Name:lower():find("lobby") or p.Team.Name:lower():find("spectator") or p.Team.Name:lower():find("waiting")) then return true end
    return false
end

local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    return line
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, v in ipairs(Players:GetPlayers()) do
                    if v ~= Player then
                        local char = v.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("Head") and char.Humanoid.Health > 0 then
                            local head = char.Head
                            local lookVector = head.CFrame.LookVector
                            local targetPos = head.Position + (lookVector * ESP_Module.Settings.Length)
                            
                            local headPos, onScreen1 = Camera:WorldToViewportPoint(head.Position)
                            local endPos, onScreen2 = Camera:WorldToViewportPoint(targetPos)
                            local dist = (Camera.CFrame.Position - head.Position).Magnitude
                            
                            local isLobby = false
                            if ESP_Module.Settings.LobbyCheck then
                                isLobby = IsInLobby(v) or IsInLobby(Player)
                            end
                            
                            if (onScreen1 or onScreen2) and not isLobby and dist <= ESP_Module.Settings.MaxDistance then
                                if not cache[v] then
                                    cache[v] = NewLine()
                                end
                                
                                local line = cache[v]
                                
                                local clr = ESP_Module.Settings.Color
                                if ESP_Module.Settings.TeamCheck and v.TeamColor ~= Player.TeamColor then
                                    clr = Color3.fromRGB(255, 0, 0)
                                elseif ESP_Module.Settings.TeamCheck and v.TeamColor == Player.TeamColor then
                                    clr = Color3.fromRGB(0, 255, 0)
                                end
                                if ESP_Module.Settings.TeamColor and v.TeamColor then
                                    clr = v.TeamColor.Color
                                end
                                
                                line.Color = clr
                                line.Thickness = ESP_Module.Settings.Thickness
                                line.Transparency = ESP_Module.Settings.Transparency
                                
                                line.From = Vector2.new(headPos.X, headPos.Y)
                                line.To = Vector2.new(endPos.X, endPos.Y)
                                line.Visible = true
                            else 
                                if cache[v] then cache[v].Visible = false end
                            end
                        else 
                            if cache[v] then cache[v].Visible = false end
                        end
                    end
                end
                
                for p, line in pairs(cache) do
                    if not p or not p.Parent then
                        line:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, line in pairs(cache) do
            if line and type(line.Remove) == "function" then
                line:Remove()
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
