local ESP_Module = {Enabled = false}

local Settings = {
    Color = Color3.fromRGB(255, 0, 0),
    Thickness = 1,
    Transparency = 1,
    AutoThickness = true,
    Length = 15,
    Smoothness = 0.2
}

local Space = game:GetService("Workspace")
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = Space.CurrentCamera
local RS = game:GetService("RunService")

local function NewLine(color, thickness)
    local line = Drawing.new("Line")
    line.Visible = false
    line.From = Vector2.new(0, 0)
    line.To = Vector2.new(0, 0)
    line.Color = color
    line.Thickness = thickness
    line.Transparency = Settings.Transparency
    return line
end

local cache = {}
local connection

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = RS.RenderStepped:Connect(function()
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= Player then
                        local char = plr.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("Head") and char.Humanoid.Health > 0 then
                            local head = char.Head
                            local _, vis = Camera:WorldToViewportPoint(head.Position)
                            if vis then
                                if not cache[plr] then
                                    cache[plr] = NewLine(Settings.Color, Settings.Thickness)
                                end
                                local tracer = cache[plr]
                                
                                local OPos = Camera:WorldToViewportPoint(head.Position)
                                local offsetCFrame = CFrame.new(0, 0, -Settings.Length)
                                local dir = head.CFrame:ToWorldSpace(offsetCFrame)
                                local offsetPos = Camera:WorldToViewportPoint(dir.Position)
                                
                                tracer.From = Vector2.new(OPos.X, OPos.Y)
                                tracer.To = Vector2.new(offsetPos.X, offsetPos.Y)
                                
                                if Settings.AutoThickness then
                                    local dist = (Camera.CFrame.Position - head.Position).Magnitude
                                    tracer.Thickness = math.clamp(1/dist*100, 1, 3)
                                else 
                                    tracer.Thickness = Settings.Thickness
                                end
                                tracer.Visible = true
                            else
                                if cache[plr] then cache[plr].Visible = false end
                            end
                        else
                            if cache[plr] then cache[plr].Visible = false end
                        end
                    end
                end
                
                for p, tracer in pairs(cache) do
                    if not p or not p.Parent then
                        tracer:Remove()
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, tracer in pairs(cache) do
            if tracer and type(tracer.Remove) == "function" then
                tracer:Remove()
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
