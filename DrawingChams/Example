local ESP_Module = {Enabled = false}

local Settings = {
    TeamCheck = true,
    Red = Color3.fromRGB(255, 0, 0),
    Green = Color3.fromRGB(0, 255, 0),
    Color = Color3.fromRGB(255, 0, 0),
    TeamColor = false
}

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Camera = game:GetService("Workspace").CurrentCamera

local function NewQuad(color)
    local quad = Drawing.new("Quad")
    quad.Visible = false
    quad.Color = color
    quad.Filled = true
    quad.Thickness = 1
    quad.Transparency = 0.25
    return quad
end

local function Colorize(color, lib)
    for _, v in pairs(lib) do
        v.Color = color
    end
end

local cache = {}
local connection

local allowedParts = {
    ["Head"] = true, ["Left Arm"] = true, ["Right Arm"] = true, 
    ["Right Leg"] = true, ["Left Leg"] = true, ["Torso"] = true,
    ["LeftHand"] = true, ["RightHand"] = true, ["LeftLowerArm"] = true, ["RightLowerArm"] = true,
    ["LeftUpperArm"] = true, ["RightUpperArm"] = true, ["LeftFoot"] = true, ["RightFoot"] = true,
    ["LeftLowerLeg"] = true, ["RightLowerLeg"] = true, ["LeftUpperLeg"] = true, ["RightUpperLeg"] = true,
    ["UpperTorso"] = true, ["LowerTorso"] = true
}

function ESP_Module:Toggle(state)
    self.Enabled = state
    if state then
        if not connection then
            connection = game:GetService("RunService").RenderStepped:Connect(function()
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= Player then
                        local char = plr.Character
                        if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                            if not cache[plr] then cache[plr] = {} end
                            local pCache = cache[plr]
                            
                            -- check parts
                            local activeParts = {}
                            for _, part in ipairs(char:GetChildren()) do
                                if part:IsA("BasePart") and (part:IsA("MeshPart") or allowedParts[part.Name]) and part.Name ~= "HumanoidRootPart" then
                                    activeParts[part] = true
                                    if not pCache[part] then
                                        pCache[part] = {
                                            NewQuad(Settings.Color), NewQuad(Settings.Color), NewQuad(Settings.Color),
                                            NewQuad(Settings.Color), NewQuad(Settings.Color), NewQuad(Settings.Color)
                                        }
                                    end
                                    
                                    local quads = pCache[part]
                                    local _, onscreen = Camera:WorldToViewportPoint(part.Position)
                                    if onscreen then
                                        local size_X = part.Size.X/2
                                        local size_Y = part.Size.Y/2
                                        local size_Z = part.Size.Z/2
                                        
                                        local Top1 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(-size_X, size_Y, -size_Z)).p)
                                        local Top2 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(-size_X, size_Y, size_Z)).p)
                                        local Top3 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(size_X, size_Y, size_Z)).p)
                                        local Top4 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(size_X, size_Y, -size_Z)).p)
                                        
                                        local Bottom1 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(-size_X, -size_Y, -size_Z)).p)
                                        local Bottom2 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(-size_X, -size_Y, size_Z)).p)
                                        local Bottom3 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(size_X, -size_Y, size_Z)).p)
                                        local Bottom4 = Camera:WorldToViewportPoint((part.CFrame * CFrame.new(size_X, -size_Y, -size_Z)).p)
                                        
                                        quads[1].PointA, quads[1].PointB, quads[1].PointC, quads[1].PointD = Vector2.new(Top1.X, Top1.Y), Vector2.new(Top2.X, Top2.Y), Vector2.new(Top3.X, Top3.Y), Vector2.new(Top4.X, Top4.Y)
                                        quads[2].PointA, quads[2].PointB, quads[2].PointC, quads[2].PointD = Vector2.new(Bottom1.X, Bottom1.Y), Vector2.new(Bottom2.X, Bottom2.Y), Vector2.new(Bottom3.X, Bottom3.Y), Vector2.new(Bottom4.X, Bottom4.Y)
                                        quads[3].PointA, quads[3].PointB, quads[3].PointC, quads[3].PointD = Vector2.new(Top1.X, Top1.Y), Vector2.new(Top2.X, Top2.Y), Vector2.new(Bottom2.X, Bottom2.Y), Vector2.new(Bottom1.X, Bottom1.Y)
                                        quads[4].PointA, quads[4].PointB, quads[4].PointC, quads[4].PointD = Vector2.new(Top2.X, Top2.Y), Vector2.new(Top3.X, Top3.Y), Vector2.new(Bottom3.X, Bottom3.Y), Vector2.new(Bottom2.X, Bottom2.Y)
                                        quads[5].PointA, quads[5].PointB, quads[5].PointC, quads[5].PointD = Vector2.new(Top3.X, Top3.Y), Vector2.new(Top4.X, Top4.Y), Vector2.new(Bottom4.X, Bottom4.Y), Vector2.new(Bottom3.X, Bottom3.Y)
                                        quads[6].PointA, quads[6].PointB, quads[6].PointC, quads[6].PointD = Vector2.new(Top4.X, Top4.Y), Vector2.new(Top1.X, Top1.Y), Vector2.new(Bottom1.X, Bottom1.Y), Vector2.new(Bottom4.X, Bottom4.Y)
                                        
                                        local clr = Settings.Color
                                        if Settings.TeamCheck then
                                            clr = (plr.TeamColor == Player.TeamColor) and Settings.Green or Settings.Red
                                        end
                                        if Settings.TeamColor and plr.TeamColor then
                                            clr = plr.TeamColor.Color
                                        end
                                        Colorize(clr, quads)
                                        for _, q in ipairs(quads) do q.Visible = true end
                                    else
                                        for _, q in ipairs(quads) do q.Visible = false end
                                    end
                                end
                            end
                            
                            for part, quads in pairs(pCache) do
                                if not activeParts[part] then
                                    for _, q in ipairs(quads) do q:Remove() end
                                    pCache[part] = nil
                                end
                            end
                        else
                            if cache[plr] then
                                for part, quads in pairs(cache[plr]) do
                                    for _, q in ipairs(quads) do q:Remove() end
                                end
                                cache[plr] = nil
                            end
                        end
                    end
                end
                
                for p, pCache in pairs(cache) do
                    if not p or not p.Parent then
                        for part, quads in pairs(pCache) do
                            for _, q in ipairs(quads) do q:Remove() end
                        end
                        cache[p] = nil
                    end
                end
            end)
        end
    else
        if connection then
            connection:Disconnect()
            connection = nil
        end
        for p, pCache in pairs(cache) do
            for part, quads in pairs(pCache) do
                for _, q in ipairs(quads) do
                    if q and type(q.Remove) == "function" then q:Remove() end
                end
            end
        end
        table.clear(cache)
    end
end

return ESP_Module
