local ESP_Module = {Enabled = false}

local DendroESP = loadstring(game:HttpGet("https://raw.githubusercontent.com/LordNahida/DendroESP/main/Source.lua"))();

function ESP_Module:Toggle(state)
    self.Enabled = state
    if type(DendroESP.Toggle) == "function" then
        DendroESP:Toggle(state)
    end
end

for _,v in pairs(game.Players:GetChildren()) do 
    if v.Character then 
       DendroESP:AddCharacter(v.Character, "Vertex") 
    end 
end 

return ESP_Module
